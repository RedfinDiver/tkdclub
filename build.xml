<?xml version="1.0" encoding="UTF-8"?>

<project name="build-tkdclub-package" default="init" basedir=".">
    
    
    <property name="name" value="tkdclub"/>
    <property name="src" location="${basedir}"/>
    <property name="build" location="${basedir}/zips"/>
    <property name="manifest" value="${src}/pkg_${name}.xml" />
    
    <target name="init">
        <mkdir dir="${build}"/>
        <echo message="Creating ${build} directory"/>
        <echo message="Name ${name} "/>
        <echo message="Build ${build} "/>
        <echo message="Manifest: ${manifest} "/>
    </target>
 
    
    <target name="zip" description="zips all files and copies them in ./package" depends="init">
        <!-- component zipping -->
        <echo message="Running package build..." />
        <echo message="Ziping ${name}-component directories..." />
        <zip destfile="${build}/com_${name}.zip">
            <zipfileset dir="${src}/component/admin" excludes="**/.svn/,**/nbproject/**,**/zip/**,*.ant,${name}.xml" prefix="admin" />
            <zipfileset dir="${src}/component/site" excludes="**/.svn/,**/nbproject/**,**/zip/**,*.ant" prefix="site"/>
            <zipfileset dir="${src}/component" excludes="**/.svn/,**/nbproject/**,**/zip/**,*.ant,**/admin/**,**/site/**" />
        </zip>
        <echo message="Ziping ${name}-modules directories..." />
        <echo message="Ziping ${name} plugins..." />
        <echo message="Ziping ${name}-quickicon-plugin ..." />
        <zip destfile="${build}/plg_quickicon_${name}logo.zip">
            <zipfileset dir="${src}/plugins/${name}logo" excludes="**/.svn/,**/nbproject/**,**/zip/**,*.ant"/>
        </zip>
        <echo message="Ziping tkdclub-grade-plugin ..." />
        <zip destfile="${build}/plg_content_tkdclubgrade.zip">
            <zipfileset dir="${src}/plugins/${name}grade" excludes="**/.svn/,**/nbproject/**,**/zip/**,*.ant"/>
        </zip>
        <copy file="${manifest}" todir="${build}"/>
        
        <!-- now ziping all the contents in {build} -->
        <echo message="Ziping tkdclub-package ..." />
        <zip destfile="${build}/pkg_tkdclub.zip">
            <zipfileset dir="${src}/zips" excludes="**/.svn/,**/nbproject/**,**/zip/**,*.ant"/>
        </zip>
        
        <!-- deleting all created zips in {build}, except pkg_tkdclub.zip -->
        <echo message="Deleting unnecessary files ..." />
        <delete includeemptydirs="true">
            <filelist
                dir="${src}/zips"
                files="com_tkdclub.zip
                       mod_tkdclub.zip
                       plg_quickicon_tkdclub.zip
                       plg_content_tkdclubgrade.zip
                       pkg_tkdclub.xml"/>
        </delete>
        
        <echo message="Packacke created!" />
        
    </target>
  
    <target name="clean" description="deletes the pkg_${name}.zip">
        <delete file="${build}/pkg_${name}.zip" />
        <echo message="pkg_${name}.zip deleted!" />
    </target>
   
</project>