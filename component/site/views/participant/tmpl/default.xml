                name="send_email"
                type="radio"
                class="btn-group btn-group-yesno"
                label="COM_TKDCLUB_FIELD_SENDEMAIL"
                description="COM_TKDCLUB_FIELD_SENDEMAIL_DESC"
                default="0">
        
